<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Territory"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="Territory.MainWindow"
        x:DataType="local:MainWindow"
        Title="Territory"
        Width="400"
        Height="450">

        <Window.Resources>
                <local:ColourConverter x:Key="ColourConverter"/>
        </Window.Resources>

        <StackPanel>
                <Border Margin="5" CornerRadius="10" Background="Gray">
                        <TextBlock Margin="5" FontSize="24" HorizontalAlignment="Center" Text="Territory"></TextBlock>
                </Border>
                
                <TextBlock Margin="5" FontSize="15" Text="Binding Player to move"></TextBlock>
                
                <Grid ShowGridLines="False" Margin="5" ColumnDefinitions="300 100" RowDefinitions="Auto">
                        <ItemsControl Name="BoardGrid" Grid.Column="0" Grid.Row="0" ItemsSource="{Binding Board.Cells}">
                                <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                                <WrapPanel></WrapPanel>
                                        </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                
                                <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:Cell">
                                                <Button Width="50" Height="50" Margin="1" 
                                                        Click="CellCLick" 
                                                        Tag="{Binding}">
                                                </Button>
                                        </DataTemplate>
                                </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <StackPanel Grid.Column="1" Grid.Row="0">
                                <Button Width="50" Margin="10">Play</Button>
                                <Button Width="50" Margin="10">Save</Button>
                                <Button Width="50" Margin="10">Load</Button>
                        </StackPanel>
                </Grid>
        </StackPanel>
</Window>
